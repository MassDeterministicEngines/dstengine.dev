---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const research = await getCollection('research');
const papers = research.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Research" description="Security research papers on AI/LLM vulnerabilities and deterministic security testing">
  <h1 class="text-3xl font-bold text-zinc-100 mb-2">Research</h1>
  <p class="text-zinc-500 mb-8">Security research on AI/LLM vulnerabilities, deterministic proof certificates, and the phoneme architecture.</p>

  <div class="space-y-4">
    {papers.map((paper) => (
      <a href={`/research/${paper.id}`} class="block border border-zinc-800 rounded-lg p-5 hover:border-zinc-600 transition-colors">
        <div class="flex items-center gap-3 mb-2">
          <span class={`text-xs font-mono px-2 py-0.5 rounded ${paper.data.status === 'published' ? 'bg-cyan-900/50 text-cyan-400' : 'bg-zinc-800 text-zinc-500'}`}>
            {paper.data.status}
          </span>
          <span class="text-xs text-zinc-600">{paper.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          {paper.data.tags.map((tag: string) => (
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-violet-900/30 text-violet-400">{tag}</span>
          ))}
        </div>
        <h3 class="text-zinc-200 font-medium text-lg">{paper.data.title}</h3>
        <p class="text-zinc-500 text-sm mt-2">{paper.data.abstract}</p>
      </a>
    ))}
  </div>

  {papers.length === 0 && (
    <p class="text-zinc-600 italic">No papers published yet. Check back soon.</p>
  )}
</Base>
